<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>pomo • Alex Lazar</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Space+Grotesk:wght@500;600&display=swap');
        
        body {
            font-family: 'Inter', system_ui, sans-serif;
        }
        
        .display {
            font-family: 'Space Grotesk', sans-serif;
        }
    </style>
</head>
<body class="bg-zinc-950 text-white min-h-screen flex items-center justify-center p-6">
    <div class="w-full max-w-md">
        
        <div class="flex justify-between items-center mb-8">
            <div class="flex items-center gap-3">
                <div class="w-9 h-9 bg-emerald-500 rounded-2xl flex items-center justify-center text-xl font-bold text-black">P</div>
                <div>
                    <h1 class="text-4xl font-semibold tracking-tighter">pomo</h1>
                    <p class="text-emerald-400 text-sm">Alex Lazar</p>
                </div>
            </div>
        </div>

        <div class="bg-zinc-900 rounded-3xl p-8 border border-zinc-700">
            
            <!-- Mode buttons -->
            <div class="flex justify-center gap-3 mb-10">
                <button onclick="setMode('work')" id="work-btn"
                    class="px-8 py-3 rounded-3xl font-medium transition-all">Work</button>
                <button onclick="setMode('break')" id="break-btn"
                    class="px-8 py-3 rounded-3xl font-medium transition-all">Break</button>
            </div>

            <!-- Timer display -->
            <div class="text-center mb-10">
                <div id="timer" class="display text-8xl font-semibold tracking-[-3px] mb-2">25:00</div>
                <div id="status" class="text-emerald-400 text-sm font-medium">Focus Time</div>
            </div>

            <!-- Controls -->
            <div class="flex justify-center gap-4">
                <button onclick="toggleTimer()" id="main-btn"
                    class="bg-emerald-500 hover:bg-emerald-600 text-black px-10 py-5 rounded-3xl font-semibold text-lg flex-1">START</button>
                <button onclick="resetTimer()"
                    class="bg-zinc-800 hover:bg-zinc-700 px-8 py-5 rounded-3xl font-semibold">RESET</button>
            </div>
        </div>

        <div class="text-center text-xs text-zinc-500 mt-8">
            Built in ~2 hours • freeCodeCamp practice
        </div>
    </div>

    <script>
        // variables for my pomodoro timer
        let timeLeft = 25 * 60;
        let timerInterval = null;
        let isRunning = false;
        let isWorkMode = true;

        const timerDisplay = document.getElementById("timer");
        const statusText = document.getElementById("status");
        const mainBtn = document.getElementById("main-btn");
        const workBtn = document.getElementById("work-btn");
        const breakBtn = document.getElementById("break-btn");

        function updateTimerDisplay() {
            let minutes = Math.floor(timeLeft / 60);
            let seconds = timeLeft % 60;
            timerDisplay.textContent = `${minutes}:${seconds < 10 ? '0' : ''}${seconds}`;
        }

        function toggleTimer() {
            if (isRunning) {
                clearInterval(timerInterval);
                mainBtn.textContent = "START";
            } else {
                timerInterval = setInterval(() => {
                    timeLeft--;
                    updateTimerDisplay();
                    
                    if (timeLeft <= 0) {
                        clearInterval(timerInterval);
                        alert("Time's up! Nice work 👍");
                        resetTimer();
                    }
                }, 1000);
                mainBtn.textContent = "PAUSE";
            }
            isRunning = !isRunning;
        }

        function resetTimer() {
            clearInterval(timerInterval);
            isRunning = false;
            mainBtn.textContent = "START";
            
            if (isWorkMode) {
                timeLeft = 25 * 60;
            } else {
                timeLeft = 5 * 60;
            }
            updateTimerDisplay();
        }

        function setMode(mode) {
            isWorkMode = mode === "work";
            
            // update button styles
            if (isWorkMode) {
                workBtn.classList.add("bg-emerald-500", "text-black");
                breakBtn.classList.remove("bg-emerald-500", "text-black");
                statusText.textContent = "Focus Time";
            } else {
                workBtn.classList.remove("bg-emerald-500", "text-black");
                breakBtn.classList.add("bg-emerald-500", "text-black");
                statusText.textContent = "Break Time";
            }
            
            resetTimer();
        }

        // keyboard shortcuts (because i like them)
        document.addEventListener("keydown", function(e) {
            if (e.key === " " || e.key === "k") {
                e.preventDefault();
                toggleTimer();
            }
            if (e.key === "r" || e.key === "R") {
                resetTimer();
            }
        });

        // start the timer
        updateTimerDisplay();
        workBtn.classList.add("bg-emerald-500", "text-black");
        
        console.log("pomo timer ready");
    </script>
</body>
</html>